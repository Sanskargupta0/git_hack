{
  "name": "git-commit-time-editor",
  "version": "0.1.0",
  "description": "Visualize and edit git commit dates/times from a GUI",
  "main": "./out/main/index.js",
  "author": "s.gupta",
  "license": "MIT",
  "scripts": {
    "gen-icon": "node scripts/gen-icon.js",
    "dev": "electron-vite dev",
    "start": "electron-vite preview",
    "build": "npm run typecheck && electron-vite build",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "build:win": "npm run gen-icon && npm run build && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --win"
  },
  "dependencies": {
    "simple-git": "^3.36.0"
  },
  "devDependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-table": "^8.21.3",
    "@types/node": "^20.19.41",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "autoprefixer": "^10.5.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cross-env": "^10.1.0",
    "date-fns": "^3.6.0",
    "electron": "^42.3.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "lucide-react": "^1.17.0",
    "next-themes": "^0.4.6",
    "postcss": "^8.5.15",
    "react": "^19.2.6",
    "react-activity-calendar": "^3.2.0",
    "react-day-picker": "^8.10.2",
    "react-dom": "^19.2.6",
    "sonner": "^2.0.7",
    "tailwindcss": "^3.4.19",
    "tailwindcss-animate": "^1.0.7",
    "tailwind-merge": "^3.6.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vite": "^7.3.5"
  }
}
